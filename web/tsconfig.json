{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["DOM", "ESNext"],
    "types": ["vite/client", "node"]
  },
  "include": ["app/**/*.ts", "components/**/*.ts", "lib/**/*.ts", "e2e/**/*.ts", "vite.config.ts", "playwright.config.ts"]
}
