FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/reference-pilot-workload ./cmd/reference-pilot-workload

FROM alpine:3.21
WORKDIR /app
COPY --from=build /out/reference-pilot-workload /app/reference-pilot-workload
EXPOSE 8080
ENTRYPOINT ["/app/reference-pilot-workload"]
