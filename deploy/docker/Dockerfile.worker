FROM golang:1.26-alpine AS build

WORKDIR /workspace
COPY go.mod ./
COPY go.sum ./
COPY cmd ./cmd
COPY db ./db
COPY internal ./internal
COPY pkg ./pkg

RUN go build -o /out/change-control-plane-worker ./cmd/worker

FROM alpine:3.21
WORKDIR /app
RUN apk add --no-cache python3
COPY --from=build /out/change-control-plane-worker /usr/local/bin/change-control-plane-worker
COPY db ./db
COPY python ./python

ENTRYPOINT ["/usr/local/bin/change-control-plane-worker"]
